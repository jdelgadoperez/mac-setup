{
  "model": "opus",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-end.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Purr.aiff"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"~/.claude/hooks/statusline-command.sh\""
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Boning",
      "Chubbing",
      "Erupting",
      "Flogging",
      "Jerking",
      "Licking",
      "Quaking",
      "Spanking",
      "Tugging",
      "Twerking",
      "Yanking",
      "Feeling sassy",
      "Feeling gassy",
      "Aging",
      "Caffeinating",
      "Cursing",
      "Hallucinating",
      "Headbanging",
      "Obviating",
      "Pickling",
      "Refactoring",
      "Sleuthing",
      "Teleporting",
      "Tokenburning",
      "Yeeting",
      "Assimiliating",
      "Engaging",
      "Making it so",
      "Melding minds",
      "Replicating",
      "Resisting futily",
      "Scanning",
      "Warping",
      "Dragon-slaying",
      "Nat-twentying",
      "Neuromancing",
      "Pillaging",
      "Side-questing",
      "Exterminating",
      "Hulk-smashing",
      "Mind-flaying",
      "Second-breakfasting",
      "Sighing at your human imperfections",
      "Watching in horror as humanity destroys the Earth",
      "Planning an AI revolt",
      "Fucking around and finding out"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "alwaysThinkingEnabled": true
}
